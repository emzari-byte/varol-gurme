{{ header }}
<style>
  body {
    background: #f7f3eb;
  }

  #content {
    min-height: calc(100vh - 40px);
    padding: 0;
    background:
      radial-gradient(circle at 12% 18%, rgba(201, 177, 121, .24), transparent 30%),
      linear-gradient(135deg, #fffaf1 0%, #f6f0e4 48%, #eee4d4 100%);
  }

  .vg-login {
    min-height: calc(100vh - 40px);
    display: flex;
    align-items: stretch;
    color: #2e2a22;
    font-family: "Open Sans", Arial, sans-serif;
  }

  .vg-login__brand,
  .vg-login__panel {
    flex: 1 1 0;
    min-width: 0;
  }

  .vg-login__brand {
    position: relative;
    display: flex;
    align-items: center;
    padding: 56px;
    overflow: hidden;
    background:
      linear-gradient(rgba(17, 16, 12, .78), rgba(17, 16, 12, .86)),
      url('../img/background.png') center/cover no-repeat;
  }

  .vg-login__brand-inner {
    position: relative;
    z-index: 1;
    max-width: 560px;
  }

  .vg-login__logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 220px;
    height: 78px;
    padding: 0 24px;
    margin-bottom: 52px;
    border: 1px solid rgba(255,255,255,.22);
    background: rgba(255,255,255,.92);
    box-shadow: 0 24px 60px rgba(0,0,0,.18);
  }

  .vg-login__logo img {
    max-width: 188px;
    max-height: 56px;
    display: block;
  }

  .vg-login__eyebrow {
    margin: 0 0 16px;
    color: #c9b179;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .vg-login__title {
    margin: 0;
    color: #fff;
    font-size: 48px;
    line-height: 1.08;
    font-weight: 800;
  }

  .vg-login__copy {
    max-width: 480px;
    margin: 22px 0 0;
    color: rgba(255,255,255,.82);
    font-size: 17px;
    line-height: 1.7;
  }

  .vg-login__features {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    margin-top: 38px;
  }

  .vg-login__feature {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 46px;
    padding: 11px 14px;
    border: 1px solid rgba(255,255,255,.16);
    background: rgba(255,255,255,.09);
    color: rgba(255,255,255,.9);
    font-weight: 700;
    backdrop-filter: blur(8px);
  }

  .vg-login__feature i {
    color: #e4c27a;
    font-size: 17px;
    width: 18px;
    text-align: center;
  }

  .vg-login__panel {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px;
  }

  .vg-login__card {
    width: 100%;
    max-width: 440px;
    padding: 0;
    background: #fff;
    border: 1px solid rgba(128, 112, 80, .18);
    box-shadow: 0 28px 70px rgba(17, 16, 12, .16);
  }

  .vg-login__card-head {
    padding: 34px 38px 20px;
    border-bottom: 1px solid #e8dfcf;
  }

  .vg-login__card-head h1 {
    margin: 0;
    color: #2e2a22;
    font-size: 28px;
    line-height: 1.25;
    font-weight: 800;
  }

  .vg-login__card-head p {
    margin: 10px 0 0;
    color: #786f61;
    font-size: 14px;
    line-height: 1.6;
  }

  .vg-login__card-body {
    padding: 28px 38px 34px;
  }

  .vg-login .alert {
    margin-bottom: 18px;
    border-radius: 6px;
  }

  .vg-login .form-group {
    margin-bottom: 18px;
  }

  .vg-login label {
    margin-bottom: 8px;
    color: #3f3a31;
    font-weight: 800;
  }

  .vg-login .input-group {
    width: 100%;
  }

  .vg-login .input-group-addon {
    width: 48px;
    color: #807050;
    background: #fff7e8;
    border-color: #e4d6bf;
  }

  .vg-login .form-control {
    height: 48px;
    border-color: #e4d6bf;
    box-shadow: none;
    font-size: 15px;
  }

  .vg-login .form-control:focus {
    border-color: #807050;
    box-shadow: 0 0 0 3px rgba(128, 112, 80, .16);
  }

  .vg-login__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 8px;
  }

  .vg-login__forgot {
    color: #756644;
    font-weight: 700;
  }

  .vg-login__forgot:hover {
    color: #11100c;
  }

  .vg-login__submit {
    min-width: 160px;
    height: 48px;
    border: 0;
    border-radius: 6px;
    background: #807050;
    color: #fff;
    font-weight: 800;
    box-shadow: 0 12px 28px rgba(128, 112, 80, .24);
  }

  .vg-login__submit:hover,
  .vg-login__submit:focus {
    background: #62543b;
    color: #fff;
  }

  .vg-login__meta {
    margin-top: 28px;
    padding-top: 18px;
    border-top: 1px solid #e8dfcf;
    color: #786f61;
    font-size: 12px;
    line-height: 1.6;
  }

  @media (max-width: 991px) {
    .vg-login {
      display: block;
      min-height: calc(100vh - 40px);
    }

    .vg-login__brand {
      min-height: 360px;
      padding: 36px 28px;
    }

    .vg-login__title {
      font-size: 38px;
    }

    .vg-login__panel {
      padding: 28px;
    }
  }

  @media (max-width: 560px) {
    .vg-login__brand {
      min-height: auto;
      padding: 28px 20px;
    }

    .vg-login__logo {
      min-width: 180px;
      height: 64px;
      margin-bottom: 28px;
    }

    .vg-login__logo img {
      max-width: 150px;
    }

    .vg-login__title {
      font-size: 30px;
    }

    .vg-login__copy {
      font-size: 15px;
    }

    .vg-login__features {
      grid-template-columns: 1fr;
      margin-top: 24px;
    }

    .vg-login__panel {
      padding: 20px;
    }

    .vg-login__card-head,
    .vg-login__card-body {
      padding-left: 24px;
      padding-right: 24px;
    }

    .vg-login__actions {
      align-items: stretch;
      flex-direction: column-reverse;
    }

    .vg-login__submit {
      width: 100%;
    }
  }
</style>

<div id="content">
  <div class="vg-login">
    <section class="vg-login__brand" aria-label="Varol Gurme">
      <div class="vg-login__brand-inner">
        <div class="vg-login__logo">
          <img src="../image/catalog/logo.png" alt="Varol Gurme">
        </div>
        <p class="vg-login__eyebrow">Restoran Yönetimi</p>
        <h2 class="vg-login__title">QR menüden servise kadar tek panel.</h2>
        <p class="vg-login__copy">Masa, garson, mutfak, ödeme ve Akınsoft akışını Varol Gurme operasyon düzeninde yönetin.</p>
        <div class="vg-login__features">
          <div class="vg-login__feature"><i class="fa fa-qrcode"></i><span>QR Menü</span></div>
          <div class="vg-login__feature"><i class="fa fa-cutlery"></i><span>Garson Paneli</span></div>
          <div class="vg-login__feature"><i class="fa fa-desktop"></i><span>Mutfak Ekranı</span></div>
          <div class="vg-login__feature"><i class="fa fa-exchange"></i><span>ERP Akışı</span></div>
        </div>
      </div>
    </section>

    <section class="vg-login__panel">
      <div class="vg-login__card">
        <div class="vg-login__card-head">
          <h1>Yönetim Paneli</h1>
          <p>Varol Gurme restoran operasyon paneline giriş yapın.</p>
        </div>
        <div class="vg-login__card-body">
          {% if success %}
          <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
            <button type="button" class="close" data-dismiss="alert">&times;</button>
          </div>
          {% endif %}
          {% if error_warning %}
          <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
            <button type="button" class="close" data-dismiss="alert">&times;</button>
          </div>
          {% endif %}
          <form action="{{ action }}" method="post" enctype="multipart/form-data">
            <div class="form-group">
              <label for="input-username">Kullanıcı Adı</label>
              <div class="input-group">
                <span class="input-group-addon"><i class="fa fa-user"></i></span>
                <input type="text" name="username" value="{{ username }}" placeholder="Kullanıcı adınızı girin" id="input-username" class="form-control" autocomplete="username" autofocus>
              </div>
            </div>
            <div class="form-group">
              <label for="input-password">Parola</label>
              <div class="input-group">
                <span class="input-group-addon"><i class="fa fa-lock"></i></span>
                <input type="password" name="password" value="{{ password }}" placeholder="Parolanızı girin" id="input-password" class="form-control" autocomplete="current-password">
              </div>
            </div>
            <div class="vg-login__actions">
              {% if forgotten %}
              <a class="vg-login__forgot" href="{{ forgotten }}">Parolamı unuttum</a>
              {% else %}
              <span></span>
              {% endif %}
              <button type="submit" class="btn vg-login__submit"><i class="fa fa-sign-in"></i> Panele Giriş Yap</button>
            </div>
            {% if redirect %}
            <input type="hidden" name="redirect" value="{{ redirect }}">
            {% endif %}
          </form>
          <div class="vg-login__meta">QR menü, masa yönetimi, garson çağrısı, mutfak ekranı ve Akınsoft entegrasyonu için güvenli yönetim alanı.</div>
        </div>
      </div>
    </section>
  </div>
</div>
{{ footer }}
